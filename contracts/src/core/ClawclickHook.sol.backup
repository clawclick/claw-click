// SPDX-License-Identifier: MIT
pragma solidity ^0.8.24;

import {BaseHook} from "../utils/BaseHook.sol";
import {IPoolManager} from "v4-core/src/interfaces/IPoolManager.sol";
import {PoolKey} from "v4-core/src/types/PoolKey.sol";
import {PoolId, PoolIdLibrary} from "v4-core/src/types/PoolId.sol";
import {BalanceDelta, toBalanceDelta} from "v4-core/src/types/BalanceDelta.sol";
import {BeforeSwapDelta, BeforeSwapDeltaLibrary, toBeforeSwapDelta} from "v4-core/src/types/BeforeSwapDelta.sol";
import {Currency, CurrencyLibrary} from "v4-core/src/types/Currency.sol";
import {Hooks} from "v4-core/src/libraries/Hooks.sol";
import {SafeCast} from "v4-core/src/libraries/SafeCast.sol";
import {IERC20} from "@openzeppelin/contracts/token/ERC20/IERC20.sol";
import {StateLibrary} from "v4-core/src/libraries/StateLibrary.sol";
import {TickMath} from "v4-core/src/libraries/TickMath.sol";

import {ClawclickConfig} from "./ClawclickConfig.sol";
import {ClawclickToken} from "./ClawclickToken.sol";

/**
 * @title ClawclickHook
 * @notice Uniswap V4 Hook for clawclick token launches
 * @dev THE BRAIN - handles all launch logic, fees, anti-snipe, and supply throttling
 * 
 * Fee Collection Architecture:
 *   - Pool fee is set to 0 (no LP fees)
 *   - Hook takes 1% fee via beforeSwap delta
 *   - Fees split 70% beneficiary / 30% platform
 *   - Fees claimable via claimBeneficiaryFees() and claimPlatformFees()
 * 
 * State Machine:
 *   PRE_LAUNCH: Token created, pool initialized, waiting for first ETH buy
 *   LIVE: First buy received, trading active with throttling
 * 
 * Key Invariants:
 *   1. First buy sets the price (no predetermined valuation)
 *   2. Anti-snipe limits buys during early blocks
 *   3. Supply released gradually to prevent dumps
 *   4. Fees collected on every swap (70% beneficiary, 30% platform)
 *   5. LP positions are permanently locked
 */
contract ClawclickHook is BaseHook {
    using PoolIdLibrary for PoolKey;
    using CurrencyLibrary for Currency;
    using SafeCast for uint256;
    using SafeCast for int256;
    using StateLibrary for IPoolManager;

    /*//////////////////////////////////////////////////////////////
                                TYPES
    //////////////////////////////////////////////////////////////*/
    
    enum LaunchState {
        PRE_LAUNCH,  // Waiting for first buyer
        LIVE         // Normal trading with throttling
    }
    
    struct TokenLaunch {
        LaunchState state;
        address token;
        address beneficiary;
        uint256 launchBlock;           // Block when first buy occurred
        uint256 launchTimestamp;       // Timestamp of first buy
        uint256 totalSupply;           // Total token supply (1B)
        uint256 supplyReleased;        // Tokens released for trading
        uint256 totalSold;             // Tokens actually sold (for throttling)
        uint256 lastReleaseBlock;      // Last block supply was released
        uint256 totalFeesEarnedETH;    // Total ETH fees collected
        uint256 totalVolumeETH;        // Total ETH volume
        uint256 totalBuys;             // Number of buy transactions
        uint256 totalSells;            // Number of sell transactions
        uint256 genesisETH;            // ETH from first buy (for anti-snipe calc)
        uint256 pendingFee;            // Fee cached in beforeSwap (prevents double-counting)
    }

    /*//////////////////////////////////////////////////////////////
                              CONSTANTS
    //////////////////////////////////////////////////////////////*/
    
    /// @notice Total supply per token (1 billion with 18 decimals)
    uint256 public constant TOTAL_SUPPLY = 1_000_000_000 * 1e18;
    
    /// @notice Basis points denominator
    uint256 public constant BPS = 10000;
    
    /// @notice Dynamic fee parameters (50% → 1% over 100 buys)
    uint256 public constant INITIAL_FEE_BPS = 5000;  // 50% on FIRST buy
    uint256 public constant FINAL_FEE_BPS = 100;     // 1% at maturity
    uint256 public constant FEE_DECAY_BUYS = 100;    // Decay over 100 buys
    
    /// @notice Minimum ETH for anti-snipe calculation (0.5 ETH floor)
    /// @dev Ensures meaningful buy limits even for small genesis buys
    uint256 public constant MIN_ANTI_SNIPE_BASE = 0.5 ether;

    /*//////////////////////////////////////////////////////////////
                                STATE
    //////////////////////////////////////////////////////////////*/
    
    /// @notice Protocol configuration
    ClawclickConfig public immutable config;
    
    /// @notice ETH represented as Currency.ADDRESS_ZERO (native ETH, no WETH)
    address public constant ETH = address(0);
    
    /// @notice Launch data per pool
    mapping(PoolId => TokenLaunch) public launches;
    
    /// @notice Accumulated ETH fees per beneficiary
    mapping(address => uint256) public beneficiaryFees;
    
    /// @notice Accumulated platform ETH fees
    uint256 public platformFees;
    
    /// @notice Per-address buy tracking during anti-snipe (poolId => address => amount)
    mapping(PoolId => mapping(address => uint256)) public antiSnipeBuys;

    /*//////////////////////////////////////////////////////////////
                                EVENTS
    //////////////////////////////////////////////////////////////*/
    
    event LaunchCreated(
        PoolId indexed poolId,
        address indexed token,
        address indexed beneficiary,
        uint256 totalSupply
    );
    
    event LaunchActivated(
        PoolId indexed poolId,
        address indexed firstBuyer,
        uint256 ethAmount,
        uint256 tokensReceived,
        uint256 launchBlock
    );
    
    event SupplyReleased(
        PoolId indexed poolId,
        uint256 newSupplyReleased,
        uint256 releaseBlock
    );
    
    event SwapExecuted(
        PoolId indexed poolId,
        address indexed trader,
        bool isBuy,
        uint256 ethAmount,
        uint256 tokenAmount,
        uint256 feeAmount
    );
    
    event FeesCollected(
        PoolId indexed poolId,
        uint256 totalFee,
        uint256 beneficiaryShare,
        uint256 platformShare
    );
    
    event FeesClaimed(
        address indexed recipient,
        uint256 amount
    );

    /*//////////////////////////////////////////////////////////////
                                ERRORS
    //////////////////////////////////////////////////////////////*/
    
    error NotFactory();
    error LaunchNotFound();
    error LaunchNotLive();
    error AntiSnipeLimitExceeded();
    error SupplyThrottled();
    error SellNotAllowedPreLaunch();
    error ProtocolPaused();
    error NoFeesToClaim();
    error NotTreasury();
    error TransferFailed();
    error LiquidityLocked();  // ✅ MINOR FIX: Use custom error consistently

    /*//////////////////////////////////////////////////////////////
                              CONSTRUCTOR
    //////////////////////////////////////////////////////////////*/
    
    constructor(
        IPoolManager _poolManager,
        ClawclickConfig _config
    ) BaseHook(_poolManager) {
        config = _config;
    }

    /*//////////////////////////////////////////////////////////////
                            HOOK PERMISSIONS
    //////////////////////////////////////////////////////////////*/
    
    function getHookPermissions() public pure override returns (Hooks.Permissions memory) {
        return Hooks.Permissions({
            beforeInitialize: true,
            afterInitialize: false,
            beforeAddLiquidity: true,
            afterAddLiquidity: false,
            beforeRemoveLiquidity: true,
            afterRemoveLiquidity: false,
            beforeSwap: true,
            afterSwap: true,
            beforeDonate: false,
            afterDonate: false,
            beforeSwapReturnDelta: true,
            afterSwapReturnDelta: false,
            afterAddLiquidityReturnDelta: false,
            afterRemoveLiquidityReturnDelta: false
        });
    }

    /*//////////////////////////////////////////////////////////////
                            FACTORY FUNCTIONS
    //////////////////////////////////////////////////////////////*/
    
    /**
     * @notice Register a new token launch
     * @dev Only callable by factory
     */
    function registerLaunch(
        PoolKey calldata key,
        address token,
        address beneficiary
    ) external {
        if (msg.sender != config.factory()) revert NotFactory();
        
        PoolId poolId = key.toId();
        
        launches[poolId] = TokenLaunch({
            state: LaunchState.PRE_LAUNCH,
            token: token,
            beneficiary: beneficiary,
            launchBlock: 0,
            launchTimestamp: 0,
            totalSupply: TOTAL_SUPPLY,
            supplyReleased: 0,
            totalSold: 0,
            lastReleaseBlock: 0,
            totalFeesEarnedETH: 0,
            totalVolumeETH: 0,
            totalBuys: 0,
            totalSells: 0,
            genesisETH: 0,
            pendingFee: 0
        });
        
        emit LaunchCreated(poolId, token, beneficiary, TOTAL_SUPPLY);
    }
    
    /**
     * @notice Approve pool manager to spend tokens (called by factory after token deploy)
     * @dev Required for adding liquidity to pool
     */
    function approvePoolManager(address token) external {
        if (msg.sender != config.factory()) revert NotFactory();
        IERC20(token).approve(address(poolManager), type(uint256).max);
    }
    
    /**
     * @notice Seed single-sided token liquidity (called by factory after token deploy)
     * @dev NEW APPROACH: Pool starts EMPTY - no upfront liquidity
     *      First swap will inject liquidity via beforeSwap delta
     *      This avoids complex v4 liquidity math and matches zero-ETH genesis
     */
    function seedLiquidity(PoolKey calldata key, address token) external {
        if (msg.sender != config.factory()) revert NotFactory();
        
        // Store token amount for use during first swap
        PoolId poolId = key.toId();
        TokenLaunch storage launch = launches[poolId];
        
        // Mark available tokens (hook holds entire supply)
        // These will be provided via swap delta during first buy
        launch.totalSupply = ClawclickToken(token).totalSupply();
        
        // No liquidity added here - pool starts empty
        // First buyer's swap will inject tokens via beforeSwap delta
    }

    /*//////////////////////////////////////////////////////////////
                            HOOK CALLBACKS
    //////////////////////////////////////////////////////////////*/
    
    function beforeInitialize(
        address sender,
        PoolKey calldata key,
        uint160
    ) external view override returns (bytes4) {
        // Only factory can initialize pools for registered launches
        if (sender != config.factory()) revert NotFactory();
        return BaseHook.beforeInitialize.selector;
    }
    
    function beforeAddLiquidity(
        address sender,
        PoolKey calldata,
        IPoolManager.ModifyLiquidityParams calldata,
        bytes calldata
    ) external view override returns (bytes4) {
        // Only factory can add initial liquidity
        if (sender != config.factory()) revert NotFactory();
        return BaseHook.beforeAddLiquidity.selector;
    }
    
    function beforeRemoveLiquidity(
        address,
        PoolKey calldata,
        IPoolManager.ModifyLiquidityParams calldata,
        bytes calldata
    ) external pure override returns (bytes4) {
        // LP positions are permanently locked - no removal ever allowed
        revert LiquidityLocked();
    }
    
    function beforeSwap(
        address sender,
        PoolKey calldata key,
        IPoolManager.SwapParams calldata params,
        bytes calldata
    ) external override returns (bytes4, BeforeSwapDelta, uint24) {
        if (config.paused()) revert ProtocolPaused();
        
        PoolId poolId = key.toId();
        TokenLaunch storage launch = launches[poolId];
        
        if (launch.token == address(0)) revert LaunchNotFound();
        
        bool isBuy = _isBuyingToken(key, params);
        uint256 inputAmount = _getInputAmount(params);
        BeforeSwapDelta delta;  // Declare once at function scope
        
        // PRE_LAUNCH: Only first buy allowed
        if (launch.state == LaunchState.PRE_LAUNCH) {
            // ✅ FIX #7: Reject second genesis attempt
            require(launch.state == LaunchState.PRE_LAUNCH, "Already launched");
            
            // ✅ FIX #4: Force EXACT INPUT swaps on genesis (amountSpecified < 0)
            require(params.amountSpecified < 0, "ExactInput only at genesis");
            
            // ✅ FIX #5: Enforce correct swap direction on genesis
            if (!isBuy) revert SellNotAllowedPreLaunch();
            
            // ✅ FIX #6: Prevent malicious partial fills on genesis
            require(params.sqrtPriceLimitX96 == 0, "No price limits at genesis");
            
            // ═══════════════════════════════════════════════════════════
            // GENESIS BUY - THE REAL, FINAL MODEL
            // ═══════════════════════════════════════════════════════════
            // 1. User sends X ETH
            // 2. Fee applies: 50% = 0.5X to hook, 0.5X to pool
            // 3. First buyer gets: FIXED 10% of supply (100M tokens)
            // 4. Pool gets: 90% of supply (900M tokens) + 0.5X ETH
            // 5. Price = 0.5X / 900M
            // 6. MC = 1B * price ≈ 1.11 * 0.5X ≈ pool depth ✓
            // 7. NO LIMITS on genesis (maxTx bypassed, anti-snipe bypassed)
            // 8. From buy #2 onward: Pure AMM + all guards
            // ═══════════════════════════════════════════════════════════
            
            launch.state = LaunchState.LIVE;
            launch.launchBlock = block.number;
            launch.launchTimestamp = block.timestamp;
            launch.lastReleaseBlock = block.number;
            launch.genesisETH = inputAmount;
            // Don't set totalBuys here - let afterSwap handle it
            
            // First buyer gets FIXED 10% allocation
            uint256 firstBuyerTokens = TOTAL_SUPPLY / 10;  // 100M tokens (10%)
            uint256 tokensToPool = TOTAL_SUPPLY - firstBuyerTokens;  // 900M tokens (90%)
            
            launch.supplyReleased = TOTAL_SUPPLY;  // All released at once
            // Don't set totalSold here - let afterSwap track actual swap amount
            
            // INJECT LIQUIDITY: Inject 90% to pool
            // First buyer will receive their 10% via the swap
            bool tokenIsCurrency1 = !_isWETHCurrency0(key);
            
            if (tokenIsCurrency1) {
                delta = toBeforeSwapDelta(0, -int128(int256(tokensToPool)));
            } else {
                delta = toBeforeSwapDelta(-int128(int256(tokensToPool)), 0);
            }
            
            // ✅ CRITICAL FIX #3: Account for genesis fee properly
            uint256 genesisFee = _getDynamicFeeRate(0);  // 50% fee
            uint256 genesisTotalFee = (inputAmount * genesisFee) / BPS;
            
            // Cache fee for afterSwap to distribute
            launch.pendingFee = genesisTotalFee;
            launch.totalVolumeETH = inputAmount;  // Track volume
            
            emit LaunchActivated(poolId, sender, inputAmount, TOTAL_SUPPLY, block.number);
            emit SupplyReleased(poolId, TOTAL_SUPPLY, block.number);
            
            // Return delta + 50% fee
            return (BaseHook.beforeSwap.selector, delta, uint24(genesisFee));
        }
        
        // LIVE: Enforce limits on SECOND buy onwards
        if (launch.state == LaunchState.LIVE) {
            if (isBuy) {
                // ANTI-SNIPE: Active for early buys (AFTER genesis)
                // totalBuys: 0=genesis, 1=second buy, 2=third buy, etc.
                // ✅ FIX #10: Use BLOCK-based anti-snipe (not buy count)
                // Apply anti-snipe during the first N blocks after launch
                bool isAntiSnipePeriod = (block.number - launch.launchBlock < config.antiSnipeBlocks());
                if (isAntiSnipePeriod) {
                    // Use _getMaxBuyAmount() for consistency with config
                    uint256 maxBuyAmount = _getMaxBuyAmount(launch);
                    
                    // Check per-address limit
                    uint256 newTotal = antiSnipeBuys[poolId][sender] + inputAmount;
                    if (newTotal > maxBuyAmount) {
                        revert AntiSnipeLimitExceeded();
                    }
                    
                    // ✅ CRITICAL FIX #1: Update anti-snipe tracking
                    antiSnipeBuys[poolId][sender] = newTotal;
                }
                
                // Note: totalBuys incremented in afterSwap
                // No supply throttling needed since all tokens released at genesis
                // Pool has full supply, AMM handles everything naturally
            }
        }
        
        // Calculate dynamic fee rate (50% → 1% over 100 buys)
        // totalBuys: 0=genesis (50%), 1=second buy (49.5%), ..., 99=100th buy (1%)
        uint256 feeBps = _getDynamicFeeRate(launch.totalBuys);
        uint256 totalFee = (inputAmount * feeBps) / BPS;
        
        // Cache fee in launch struct (afterSwap will use this exact amount)
        launch.pendingFee = totalFee;
        launch.totalVolumeETH += inputAmount;
        
        // The hook takes the fee by specifying a delta
        // For exactInput swaps: hook takes fee from input currency
        // This is achieved by returning a positive delta for the input currency
        // (positive delta = hook receives, negative delta = hook pays)
        
        int128 feeDelta = int128(int256(totalFee));
        
        if (isBuy) {
            // Buying token: input is ETH (currency0 or currency1 depending on sort)
            if (_isWETHCurrency0(key)) {
                // ETH is currency0, token is currency1
                // Hook takes fee from currency0 (ETH)
                delta = toBeforeSwapDelta(feeDelta, 0);
            } else {
                // Token is currency0, ETH is currency1
                // Hook takes fee from currency1 (ETH)
                delta = toBeforeSwapDelta(0, feeDelta);
            }
        } else {
            // Selling token: input is token
            if (_isWETHCurrency0(key)) {
                // ETH is currency0, token is currency1
                // Hook takes fee from currency1 (token)
                delta = toBeforeSwapDelta(0, feeDelta);
            } else {
                // Token is currency0, ETH is currency1
                // Hook takes fee from currency0 (token)
                delta = toBeforeSwapDelta(feeDelta, 0);
            }
        }
        
        // Return the fee delta with dynamic fee rate
        // v4 will use this rate for the swap
        return (BaseHook.beforeSwap.selector, delta, uint24(feeBps));
    }
    
    function afterSwap(
        address sender,
        PoolKey calldata key,
        IPoolManager.SwapParams calldata params,
        BalanceDelta delta,
        bytes calldata
    ) external override returns (bytes4, int128) {
        PoolId poolId = key.toId();
        TokenLaunch storage launch = launches[poolId];
        
        if (launch.token == address(0)) return (BaseHook.afterSwap.selector, 0);
        
        bool isBuy = _isBuyingToken(key, params);
        uint256 inputAmount = _getInputAmount(params);
        uint256 tokenAmount = _getTokenAmount(delta, key);
        
        // Track buy/sell counts
        if (isBuy) {
            launch.totalBuys++;
            // ⚠️ MEDIUM FIX: totalSold tracking removed - no longer needed without supply throttling
            // Kept in struct for backwards compatibility but not actively tracked
        } else {
            launch.totalSells++;
        }
        
        // ✅ FIX #8 & #9: Use cached fee with safety checks
        require(launch.pendingFee <= inputAmount, "Fee overflow");
        require(launch.pendingFee == (inputAmount * _getDynamicFeeRate(launch.totalBuys)) / BPS, "Fee mismatch");
        
        uint256 totalFee = launch.pendingFee;
        launch.pendingFee = 0;  // Reset for next swap
        
        if (totalFee > 0) {
            // Split and distribute fees
            (,uint256 beneficiaryShare, uint256 platformShare) = config.calculateFees(totalFee);
            
            launch.totalFeesEarnedETH += totalFee;
            beneficiaryFees[launch.beneficiary] += beneficiaryShare;
            platformFees += platformShare;
            
            emit FeesCollected(poolId, totalFee, beneficiaryShare, platformShare);
        }
        
        emit SwapExecuted(poolId, sender, isBuy, inputAmount, tokenAmount, totalFee);
        
        return (BaseHook.afterSwap.selector, -int128(uint128(totalFee)));
    }

    /*//////////////////////////////////////////////////////////////
                         SUPPLY THROTTLING
    //////////////////////////////////////////////////////////////*/
    
    /**
     * @notice Update supply release based on blocks elapsed
     * @dev Called on every swap to gradually release more supply
     */
    // Supply release removed - all tokens released at genesis
    // No gradual release mechanism needed
    
    /**
     * @notice Get max buy amount during anti-snipe period
     * @dev Uses genesisETH as base (with minimum floor) * maxBuyBps
     *      With 200 bps (2%), if genesis was 0.1 ETH, max buy = 0.002 ETH per address
     *      This allows ~50 addresses to buy at max before exhausting genesis equivalent
     */
    function _getMaxBuyAmount(TokenLaunch storage launch) internal view returns (uint256) {
        // Use the larger of: genesis ETH or minimum floor
        uint256 baseAmount = launch.genesisETH > MIN_ANTI_SNIPE_BASE 
            ? launch.genesisETH 
            : MIN_ANTI_SNIPE_BASE;
        
        // Max buy = base * antiSnipeMaxBuyBps / BPS
        // With 200 bps, this is 2% of the base amount per address
        return (baseAmount * config.antiSnipeMaxBuyBps()) / BPS;
    }
    
    /**
     * @notice Get dynamic fee rate based on buy count
     * @dev Starts at 50%, decays to 1% over 100 buys
     */
    function _getDynamicFeeRate(uint256 buyCount) internal pure returns (uint256) {
        if (buyCount >= FEE_DECAY_BUYS) return FINAL_FEE_BPS;
        
        // Linear decay: 50% - (buyCount * 49% / 100)
        uint256 decayAmount = (buyCount * (INITIAL_FEE_BPS - FINAL_FEE_BPS)) / FEE_DECAY_BUYS;
        return INITIAL_FEE_BPS - decayAmount;
    }

    /*//////////////////////////////////////////////////////////////
                            FEE CLAIMING
    //////////////////////////////////////////////////////////////*/
    
    /**
     * @notice Claim accumulated beneficiary fees (in native ETH)
     */
    function claimBeneficiaryFees() external {
        uint256 amount = beneficiaryFees[msg.sender];
        if (amount == 0) revert NoFeesToClaim();
        
        beneficiaryFees[msg.sender] = 0;
        
        // Transfer native ETH
        (bool success, ) = msg.sender.call{value: amount}("");
        if (!success) revert TransferFailed();
        
        emit FeesClaimed(msg.sender, amount);
    }
    
    /**
     * @notice Claim platform fees (treasury only, in native ETH)
     */
    function claimPlatformFees() external {
        if (msg.sender != config.treasury()) revert NotTreasury();
        
        uint256 amount = platformFees;
        if (amount == 0) revert NoFeesToClaim();
        
        platformFees = 0;
        
        // Transfer native ETH
        (bool success, ) = msg.sender.call{value: amount}("");
        if (!success) revert TransferFailed();
        
        emit FeesClaimed(msg.sender, amount);
    }

    /*//////////////////////////////////////////////////////////////
                            VIEW FUNCTIONS
    //////////////////////////////////////////////////////////////*/
    
    function getLaunch(PoolId poolId) external view returns (TokenLaunch memory) {
        return launches[poolId];
    }
    
    function isLive(PoolId poolId) external view returns (bool) {
        return launches[poolId].state == LaunchState.LIVE;
    }
    
    function getBlocksSinceLaunch(PoolId poolId) external view returns (uint256) {
        TokenLaunch storage launch = launches[poolId];
        if (launch.state != LaunchState.LIVE) return 0;
        return block.number - launch.launchBlock;
    }
    
    function getCurrentSupplyReleased(PoolId poolId) external view returns (uint256) {
        TokenLaunch storage launch = launches[poolId];
        if (launch.state != LaunchState.LIVE) return 0;
        
        // All tokens released at genesis
        return TOTAL_SUPPLY;
    }
    
    function isInAntiSnipePeriod(PoolId poolId) external view returns (bool) {
        TokenLaunch storage launch = launches[poolId];
        if (launch.state != LaunchState.LIVE) return false;
        return block.number - launch.launchBlock < config.antiSnipeBlocks();
    }
    
    function getAntiSnipeBuyLimit(PoolId poolId) external view returns (uint256) {
        TokenLaunch storage launch = launches[poolId];
        if (launch.state != LaunchState.LIVE) return 0;
        return _getMaxBuyAmount(launch);
    }
    
    function getLaunchState(PoolId poolId) external view returns (
        uint256 totalSold,
        uint256 supplyReleased,
        uint256 totalBuys,
        uint256 beneficiaryFeesAccrued,
        uint256 platformFeesAccrued,
        uint256 totalVolume
    ) {
        TokenLaunch storage launch = launches[poolId];
        return (
            launch.totalSold,
            launch.supplyReleased,
            launch.totalBuys,
            beneficiaryFees[launch.beneficiary],
            platformFees,
            launch.totalVolumeETH
        );
    }
    
    function getRemainingAntiSnipeBudget(PoolId poolId, address buyer) external view returns (uint256) {
        TokenLaunch storage launch = launches[poolId];
        if (launch.state != LaunchState.LIVE) return 0;
        if (block.number - launch.launchBlock >= config.antiSnipeBlocks()) {
            return type(uint256).max; // No limit after anti-snipe
        }
        uint256 maxBuy = _getMaxBuyAmount(launch);
        uint256 spent = antiSnipeBuys[poolId][buyer];
        return spent >= maxBuy ? 0 : maxBuy - spent;
    }

    /*//////////////////////////////////////////////////////////////
                      MARKET CAP & PRICE VIEWS
    //////////////////////////////////////////////////////////////*/
    
    /**
     * @notice Get current token price in ETH (price of 1 token with 18 decimals)
     * @param key Pool key
     * @return priceInETH Price of 1 token in ETH (18 decimals)
     * 
     * ✅ MINOR FIX: Added explicit comments for inversion logic
     */
    function getTokenPrice(PoolKey calldata key) external view returns (uint256 priceInETH) {
        (uint160 sqrtPriceX96,,,) = poolManager.getSlot0(key.toId());
        
        // sqrtPriceX96 = sqrt(price) * 2^96
        // price = (sqrtPriceX96 / 2^96)^2
        
        bool tokenIsCurrency0 = Currency.unwrap(key.currency0) != ETH;
        
        // Calculate price using the formula: price = (sqrtPriceX96 ** 2) / (2 ** 192)
        uint256 sqrtPrice = uint256(sqrtPriceX96);
        uint256 priceX192 = sqrtPrice * sqrtPrice;
        
        if (tokenIsCurrency0) {
            // Token is currency0, so price = currency1/currency0 = ETH/Token
            // Result: priceInETH = ETH per token, 18 decimals
            priceInETH = (priceX192 * 1e18) >> 192;
        } else {
            // Token is currency1, so price = currency0/currency1 = Token/ETH  
            // We need: ETH/Token = 1 / (Token/ETH)
            // Inversion: safe because priceX192 > 0 after first swap
            // Result: priceInETH = ETH per token, 18 decimals
            priceInETH = (1e18 << 192) / priceX192;
        }
        
        return priceInETH;
    }
    
    /**
     * @notice Get current market cap in ETH
     * @param key Pool key
     * @return marketCapETH Market cap in ETH
     */
    function getMarketCap(PoolKey calldata key) external view returns (uint256 marketCapETH) {
        TokenLaunch storage launch = launches[key.toId()];
        if (launch.state != LaunchState.LIVE) return 0;
        
        (uint160 sqrtPriceX96,,,) = poolManager.getSlot0(key.toId());
        bool tokenIsCurrency0 = Currency.unwrap(key.currency0) != ETH;
        
        uint256 sqrtPrice = uint256(sqrtPriceX96);
        uint256 priceX192 = sqrtPrice * sqrtPrice;
        uint256 priceInETH;
        
        if (tokenIsCurrency0) {
            priceInETH = (priceX192 * 1e18) >> 192;
        } else {
            priceInETH = (1e18 << 192) / priceX192;
        }
        
        // Market cap = total supply * price per token
        marketCapETH = (TOTAL_SUPPLY * priceInETH) / 1e18;
        return marketCapETH;
    }
    
    /**
     * @notice Get pool liquidity depth (ETH in pool)
     * @param key Pool key
     * @return liquidityETH Amount of ETH in the pool
     * 
     * ✅ CRITICAL FIX #2: This function removed - balanceOf() returns hook balance, not pool reserves
     * Pool reserves are tracked in PoolManager's internal accounting, not accessible via simple view
     * Use launch.totalVolumeETH or on-chain queries instead
     * Better to have no metric than a lying metric
     */
    // function getPoolLiquidityETH() - REMOVED (was incorrect)
    
    /**
     * @notice Get MC/LP ratio (market cap divided by liquidity)
     * @param key Pool key
     * @return ratio MC/LP ratio (multiplied by 1000 for precision, e.g., 20000 = 20x)
     * 
     * ✅ FIX: Removed MC/LP calculation - liquidity not reliably queryable
     * Use totalVolumeETH from launch state instead if needed
     */
    function getMCLPRatio(PoolKey calldata key) external view returns (uint256 ratio) {
        // REMOVED: balanceOf() doesn't give pool reserves
        // Better to return 0 than lie
        return 0;
    }
    
    /**
     * @notice Get comprehensive pool metrics
     * @param key Pool key
     * @return priceInETH Token price in ETH (18 decimals)
     * @return marketCapETH Market cap in ETH
     * @return totalVolumeETH Total ETH volume traded
     * @return totalBuys Number of buys
     * @return totalFeesETH Total fees collected
     */
    function getPoolMetrics(PoolKey calldata key) external view returns (
        uint256 priceInETH,
        uint256 marketCapETH,
        uint256 totalVolumeETH,
        uint256 totalBuys,
        uint256 totalFeesETH
    ) {
        TokenLaunch storage launch = launches[key.toId()];
        if (launch.state != LaunchState.LIVE) {
            return (0, 0, 0, 0, 0);
        }
        
        // Get sqrt price
        (uint160 sqrtPriceX96,,,) = poolManager.getSlot0(key.toId());
        bool tokenIsCurrency0 = Currency.unwrap(key.currency0) != ETH;
        
        uint256 sqrtPrice = uint256(sqrtPriceX96);
        uint256 priceX192 = sqrtPrice * sqrtPrice;
        
        // Calculate price (ETH per token, 18 decimals)
        if (tokenIsCurrency0) {
            priceInETH = (priceX192 * 1e18) >> 192;
        } else {
            priceInETH = (1e18 << 192) / priceX192;
        }
        
        // Calculate market cap
        marketCapETH = (TOTAL_SUPPLY * priceInETH) / 1e18;
        
        // Use tracked metrics instead of broken liquidity query
        totalVolumeETH = launch.totalVolumeETH;
        totalBuys = launch.totalBuys;
        totalFeesETH = launch.totalFeesEarnedETH;
        
        return (priceInETH, marketCapETH, totalVolumeETH, totalBuys, totalFeesETH);
    }

    /*//////////////////////////////////////////////////////////////
                            INTERNAL HELPERS
    //////////////////////////////////////////////////////////////*/
    
    function _isBuyingToken(
        PoolKey calldata key,
        IPoolManager.SwapParams calldata params
    ) internal view returns (bool) {
        bool ethIsCurrency0 = _isWETHCurrency0(key);
        
        // zeroForOne = swapping currency0 for currency1
        // Buy = swapping ETH for token
        if (ethIsCurrency0) {
            return params.zeroForOne; // ETH -> Token
        } else {
            return !params.zeroForOne; // Token is currency0, !zeroForOne = ETH -> Token
        }
    }
    
    function _isWETHCurrency0(PoolKey calldata key) internal pure returns (bool) {
        return Currency.unwrap(key.currency0) == ETH;
    }
    
    function _getInputAmount(
        IPoolManager.SwapParams calldata params
    ) internal pure returns (uint256) {
        return params.amountSpecified > 0 
            ? uint256(params.amountSpecified) 
            : uint256(-params.amountSpecified);
    }
    
    function _getTokenAmount(
        BalanceDelta delta,
        PoolKey calldata key
    ) internal view returns (uint256) {
        bool tokenIsCurrency1 = _isWETHCurrency0(key);
        
        int128 amount = tokenIsCurrency1 ? delta.amount1() : delta.amount0();
        return amount > 0 ? uint256(int256(amount)) : uint256(int256(-amount));
    }
    
    /**
     * @notice Conservative estimate of token output for a buy
     * @dev Returns a safe upper bound to prevent exceeding supply limits
     *      Uses amountSpecified as worst-case (assumes 1:1 price)
     */
    function _estimateTokenOutput(IPoolManager.SwapParams calldata params) internal pure returns (uint256) {
        // Conservative: assume all input becomes output (worst case for throttling)
        // In reality, output will be less due to price impact
        uint256 inputAmount = params.amountSpecified > 0 
            ? uint256(params.amountSpecified) 
            : uint256(-params.amountSpecified);
        return inputAmount;  // Conservative upper bound
    }
    
    /// @notice Receive ETH for fee collection
    receive() external payable {}
}
