{
  "name": "clawclick-sdk",
  "version": "0.1.7",
  "description": "CLI & SDK for Claw.Click agents — launch tokens, trade, upload images, claim fees",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clawclick": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "clawclick",
    "uniswap-v4",
    "token-launcher",
    "agent-sdk"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*"
  ],
  "dependencies": {
    "viem": "^2.7.15",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "dotenv": "^16.4.1",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
