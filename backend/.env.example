# Chain — 8453 = Base mainnet (default), 11155111 = Sepolia
CHAIN_ID=8453

# RPC (optional — auto-built from ALCHEMY_API_KEY if not set)
# RPC_URL=https://mainnet.base.org
# WS_RPC_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# API keys (at least one recommended for reliability)
ALCHEMY_API_KEY=your_alchemy_api_key_here
INFURA_PROJECT_ID=your_infura_project_id_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/clawclick

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379

# API Server
PORT=3001
NODE_ENV=development

# Contract Addresses — Base Mainnet
FACTORY_ADDRESS=0xF5979D0fEEd05CEcb94cf62B76FE7E9aB40c6b4a
HOOK_ADDRESS=0x8265be7eb9D7e40c1FAb6CBd8DBc626b31A0aac8
POOL_MANAGER_ADDRESS=0x498581fF718922c3f8e6A244956aF099B2652b2b

# Supabase (image uploads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
